<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF5ED">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <fragment
            android:id="@+id/map_fragment"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="@dimen/main_content_padding">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#FCFFFB"
                app:cardCornerRadius="24dp"
                app:cardElevation="6dp"
                app:strokeColor="#C7D9C8"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/reserve_name_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/map_heading"
                                android:textColor="#264F39"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/location_hint_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/location_unavailable"
                                android:textColor="#5B7661"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/event_count_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/event_count_default"
                        android:textColor="#355B45"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/status_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/status_loading_map"
                        android:textColor="#6B7D6D"
                        android:textSize="12sp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginTop="@dimen/control_stack_margin_top"
                android:gravity="start"
                android:orientation="vertical">

                <View
                    android:layout_width="1dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/menu_button"
                    android:layout_width="@dimen/map_round_button_size"
                    android:layout_height="@dimen/map_round_button_size"
                    android:layout_gravity="start"
                    android:background="@drawable/bg_map_round_button"
                    android:contentDescription="@string/open_menu"
                    android:padding="12dp"
                    android:src="@drawable/ic_menu_hamburger"
                    android:tint="#466B51" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/my_location_button"
                    android:layout_width="@dimen/map_round_button_size"
                    android:layout_height="@dimen/map_round_button_size"
                    android:background="@drawable/bg_map_round_button"
                    android:contentDescription="@string/my_location"
                    android:padding="14dp"
                    android:src="@android:drawable/ic_menu_mylocation"
                    android:tint="#496D54" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/north_up_button"
                    android:layout_width="@dimen/map_round_button_size"
                    android:layout_height="@dimen/map_round_button_size"
                    android:background="@drawable/bg_map_round_button"
                    android:contentDescription="@string/north_up"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:padding="0dp"
                    android:text="@string/north_up_short"
                    android:textAllCaps="false"
                    android:textColor="#496D54"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/weather_toggle_button"
                    android:layout_width="@dimen/map_round_button_size"
                    android:layout_height="@dimen/map_round_button_size"
                    android:background="@drawable/bg_map_round_button_inactive"
                    android:contentDescription="@string/weather_toggle_off"
                    android:padding="12dp"
                    android:src="@drawable/ic_weather_sun_cloud"
                    android:tint="#496D54" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <View
                android:id="@+id/bottom_spacer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/report_toggle_button"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/report_event_button"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                app:backgroundTint="#6D9771"
                app:cornerRadius="18dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/report_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:maxHeight="@dimen/report_panel_max_height"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:cardBackgroundColor="#FCFFFB"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeColor="#C7D9C8"
                app:strokeWidth="1dp">

                <ScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fillViewport="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/report_heading"
                        android:textColor="#264F39"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/report_subheading"
                        android:textColor="#5B7661"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/report_location_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/report_location_waiting"
                        android:textColor="#446B52"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/manual_location_button"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/report_pick_map_location"
                        android:textAllCaps="false"
                        android:textColor="#41624A"
                        app:cornerRadius="16dp"
                        app:strokeColor="#A4BCA8" />

                    <Spinner
                        android:id="@+id/reserve_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:backgroundTint="#6D9771" />

                    <EditText
                        android:id="@+id/reporter_name_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/reporter_name"
                        android:inputType="textPersonName" />

                    <Spinner
                        android:id="@+id/report_type_spinner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp" />

                    <EditText
                        android:id="@+id/report_description_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="top|start"
                        android:hint="@string/event_description"
                        android:inputType="textMultiLine"
                        android:minLines="3" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/capture_photo_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:backgroundTint="#E3EFE2"
                            android:text="@string/capture_photo"
                            android:textColor="#365843" />

                        <Button
                            android:id="@+id/attach_media_button"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:backgroundTint="#E3EFE2"
                            android:text="@string/attach_media"
                            android:textColor="#365843" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/selected_media_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="@string/selected_media_none"
                        android:textColor="#5B7661"
                        android:textSize="13sp" />

                    <Button
                        android:id="@+id/submit_report_button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:backgroundTint="#6D9771"
                        android:text="@string/submit_report"
                        android:textColor="#FFFFFF" />

                    </LinearLayout>
                </ScrollView>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/weather_overlay"
            android:layout_width="@dimen/weather_overlay_width"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="@dimen/weather_overlay_margin_end"
            android:layout_marginBottom="@dimen/weather_overlay_margin_bottom"
            android:visibility="gone"
            app:cardBackgroundColor="#FCFFFB"
            app:cardCornerRadius="18dp"
            app:cardElevation="6dp"
            app:strokeColor="#C7D9C8"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/weather_now_text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/weather_loading"
                        android:textColor="#2F6E4A"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ImageButton
                        android:id="@+id/weather_expand_button"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@android:color/transparent"
                        android:contentDescription="@string/weather_expand"
                        android:padding="4dp"
                        android:src="@android:drawable/arrow_down_float"
                        android:tint="#496D54" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/weather_hourly_panel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/weather_hourly_title"
                        android:textColor="#477160"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/weather_hourly_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/weather_hourly_loading"
                        android:textColor="#477160"
                        android:textSize="11sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <LinearLayout
        android:layout_width="@dimen/drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FCFFFB"
        android:orientation="vertical"
        android:padding="@dimen/drawer_padding">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/drawer_title"
            android:textColor="#264F39"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/drawer_subtitle"
            android:textColor="#5B7661"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/server_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/server_status_checking"
            android:textColor="#735A2E"
            android:textSize="12sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="18dp"
            android:background="#DCE7DC" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/drawer_map_section"
            android:textColor="#355B45"
            android:textSize="14sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/poi_toggle_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:textAllCaps="false"
            android:textColor="#41624A"
            app:cornerRadius="18dp"
            app:strokeColor="#A4BCA8" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/hazard_toggle_button"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textAllCaps="false"
            android:textColor="#41624A"
            app:cornerRadius="18dp"
            app:strokeColor="#A4BCA8" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
